{
    "name": "gtgt/symfony-ai-copilot-platform",
    "description": "Symfony AI Platform bridge for GitHub Copilot (Cloud Agent Tasks API and local copilot CLI)",
    "type": "symfony-bundle",
    "license": "LGPL-3.0-or-later",
    "require": {
        "php": ">=8.2",
        "symfony/ai-platform": "^0.9",
        "symfony/config": "^7.4|^8.0",
        "symfony/dependency-injection": "^7.4|^8.0",
        "symfony/http-client": "^7.4|^8.0",
        "symfony/http-kernel": "^7.4|^8.0",
        "symfony/process": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Symfony\\AI\\Platform\\Bridge\\Copilot\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "bundle": [
                "Symfony\\AI\\Platform\\Bridge\\Copilot\\Bundle"
            ]
        }
    }
}
